# Supabase project — frontend uses anon/publishable key only
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# FastAPI backend
VITE_API_URL=http://localhost:8000
# Static Bearer token shared with backend's API_TOKEN env. Same value on
# both sides — see backend/.env.example.
VITE_API_TOKEN=

# Demo train marker speed (km/h). 150 is realistic freight rail; bump to
# 600+ for a visually faster demo on zoomed-out maps. Default if unset: 150.
VITE_TRAIN_SPEED_KMH=150
