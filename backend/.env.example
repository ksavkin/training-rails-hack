APP_NAME=training-rails
HOST=0.0.0.0
PORT=8000
RELOAD=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_STORAGE_BUCKET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SANDBOX_FROM=
PERSONAL_PHONE=

# Static bearer token guarding mutation endpoints (/detect, /dispatch,
# /pins/{id}/acknowledge, /pins/{id}/resolve). Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Frontend must use the SAME value via VITE_API_TOKEN. Jetson sends it in
# the Authorization: Bearer <token> header on /detect.
API_TOKEN=

# Comma-separated allowlist for CORS preflight. Include your Vercel
# frontend URL in production, e.g. "https://training-rails.vercel.app".
# Defaults to "http://localhost:5173,http://127.0.0.1:5173" if unset.
CORS_ORIGINS=
